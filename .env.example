# Copy this file to .env for local development.
# make dev keeps userkit disabled by default.
# make dev-up starts PostgreSQL, runs migrations, and enables userkit.

APP_NAME=go-modular-starter
APP_ENV=development
APP_VERSION=dev
APP_COMMIT=local
APP_BUILD_TIME=local

HTTP_ADDR=:8080
HTTP_READ_HEADER_TIMEOUT=5s
HTTP_READ_TIMEOUT=15s
HTTP_WRITE_TIMEOUT=30s
HTTP_IDLE_TIMEOUT=60s
HTTP_SHUTDOWN_TIMEOUT=15s
HTTP_MAX_HEADER_BYTES=1048576
HTTP_BODY_LIMIT_BYTES=1048576
HTTP_CORS_ALLOWED_ORIGINS=http://localhost:3000

LOG_LEVEL=info
LOG_FORMAT=text

USERKIT_ENABLED=false
USERKIT_DATABASE_URL=postgres://starter:starter@localhost:55432/starter?sslmode=disable
USERKIT_DB_MAX_OPEN_CONNS=10
USERKIT_DB_MAX_IDLE_CONNS=5
USERKIT_DB_CONN_MAX_LIFETIME=30m
USERKIT_DB_CONN_MAX_IDLE_TIME=5m
USERKIT_JWT_SECRET=change-me-to-a-long-random-secret
USERKIT_JWT_ISSUER=go-modular-starter
USERKIT_JWT_AUDIENCE=go-modular-starter-users
USERKIT_TOKEN_TTL=24h
USERKIT_BCRYPT_COST=0
